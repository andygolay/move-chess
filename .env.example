# Chess Module Addresses
# Deploy to each network and set the corresponding address:
# movement move publish --named-addresses chess=<your-address>
#
# The app detects the network via sdk.network ('testnet' or 'mainnet')
# and uses the correct contract address automatically.
NEXT_PUBLIC_CHESS_MODULE_ADDRESS_TESTNET=
NEXT_PUBLIC_CHESS_MODULE_ADDRESS_MAINNET=
